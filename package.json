{
  "name": "izichangepay",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript wrapper for the IziChange payment API",
  "keywords": [
    "izichange",
    "payment",
    "crypto",
    "west-africa",
    "typescript",
    "api"
  ],
  "license": "MIT",
  "author": "chaldrakus@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaldrak/izichangepay"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:fix-pkg",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:fix-pkg": "node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'},null,2))\" && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'},null,2))\"",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck",
    "prepare": "husky",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@jest/globals": "^29",
    "@types/node": "^20",
    "husky": "^9",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
